# Environment Configuration (Optional)
# Copy this file to .env if you need custom configuration

# Chatbot URL (if different from default)
# CHATBOT_URL=https://pib.myscheme.in/

# API Endpoint (if different from default)
# API_ENDPOINT=https://pib.myscheme.in/api/chat

# Test Configuration
# MAX_TIMEOUT=120000
# API_TIMEOUT=60000

# Reporting
# REPORTS_DIR=./reports
# DATASETS_DIR=./datasets

# Debug Mode
# DEBUG=false
# HEADED=false
